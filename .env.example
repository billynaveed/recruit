# Copy this file to `.env` and fill in real values. Never commit `.env`.

# --- Database -------------------------------------------------------------
# PostgreSQL connection string.
DATABASE_URL=postgresql://user:password@localhost:5432/recruit

# --- Sessions -------------------------------------------------------------
# Random secret used to encrypt the iron-session cookie. Minimum 32 chars.
# Generate one with: openssl rand -base64 32
SESSION_SECRET=at-least-32-characters-long-random-secret-here
# Set to "true" when serving over HTTPS so cookies get the Secure flag.
# Leave "false" for plain-HTTP local development.
COOKIE_SECURE=false

# --- Admin authentication (Google Sign-In) --------------------------------
# Google Workspace hosted domain allowed to sign in to the admin area. Every
# admin signs in with a Google account on this domain. REQUIRED — sign-in is
# blocked until this matches your organization's domain.
ADMIN_HOSTED_DOMAIN=example.com
# Google OAuth client ID (from Google Cloud Console). Required for sign-in.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# Optional: comma-separated emails to seed the reviewer picker before anyone
# has logged in. Each must be on ADMIN_HOSTED_DOMAIN. Safe to leave blank.
ADMIN_EMAILS=

# --- AI scoring -----------------------------------------------------------
# Required for AI rubric scoring of STAR behavioral responses.
# Uses the claude-sonnet-4-6 model via @anthropic-ai/sdk.
ANTHROPIC_API_KEY=sk-ant-...

# --- Branding / public copy ----------------------------------------------
# Public origin used to build candidate-facing links and report URLs.
NEXT_PUBLIC_BASE_URL=http://localhost:3000
# Names and contact email shown in the UI, privacy policy, and terms of use.
NEXT_PUBLIC_APP_NAME=Recruit
NEXT_PUBLIC_ORG_NAME=Your Organization
NEXT_PUBLIC_CONTACT_EMAIL=privacy@example.com

# --- Logging --------------------------------------------------------------
# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# --- Uploads --------------------------------------------------------------
# Optional: directory for uploaded CV files (defaults to a local path).
# UPLOADS_DIR=/var/recruit/uploads

# --- Error monitoring (optional) ------------------------------------------
# Sentry is a no-op unless these are set. See https://sentry.io
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Build-time only, for source-map upload:
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
